APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Use the port you serve on (e.g. 8000 for `./docker-dev.sh`). Wrong APP_URL breaks product image URLs.
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# Local file DB (no Docker MariaDB): create database/database.sqlite or use mysql below.

# --- Docker dev (`./docker-dev.sh`) uses MariaDB in Compose; DB_* below seed the container ---
# DB_CONNECTION is overridden to mysql for the `app` service by docker-compose.dev.yml.
# DB_HOST=127.0.0.1
# DB_PORT=3307
# DB_DATABASE=othbar
# DB_USERNAME=othbar
# DB_PASSWORD=othbar
# MYSQL_ROOT_PASSWORD=devroot
# MYSQL_PUBLISH_PORT=3307
# For PHP on your host only: DB_PORT must match MYSQL_PUBLISH_PORT. Avoid `php artisan config:cache` locally — it freezes DB_* and breaks the Docker app; use `config:clear`.

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Filament product photos use the public disk (see AppServiceProvider). Optional override:
# FILAMENT_FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Admin (Filament) ---
# Panel URL: /admin/login (e.g. http://localhost:8000/admin/login with docker-dev.sh)

# Default admin (DatabaseSeeder → AdminUserSeeder). Change password in production.
ADMIN_EMAIL=admin@othbar.local
ADMIN_PASSWORD=password

VITE_APP_NAME="${APP_NAME}"
