# Merged after `.env` by docker-compose.dev.yml so the PHP container always reaches the `mariadb` service,
# even when `.env` keeps host-oriented DB_HOST / DB_PORT for running Artisan on the machine without Docker.
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
# If .env sets DB_URL for host access (127.0.0.1:3307), Laravel uses it and ignores DB_HOST — unset for Docker.
DB_URL=
